{% extends 'layouts/main.html.twig' %}
{% block title %}
    {{ 'gin_ranking.title'|trans }}
{% endblock %}

{% block heading %}
    <h1>{{ 'gin_ranking.title'|trans }}</h1>
{% endblock %}

{% block content %}
    <div class="page-content d-flex flex-column flex-md-row mx-auto">
        {% if form.vars.imageToRender is defined and form.vars.imageToRender is not null %}
            <img class="gin-ranking-edit__img" src="{{ asset_s3(form.vars.imageToRender) }}" alt="{{ form.name.vars.data }}"/>
        {% endif %}
        {{ form_start(form, {attr: {class: 'w-100 w-md-75'}}) }}
            {{ form_row(form.name) }}
            {{ form_row(form.category) }}
            {{ form_row(form.image) }}
            <twig:Button class="w-100" type="submit">{{ 'gin_ranking.form.edit.submit'|trans }}</twig:Button>
        {{ form_end(form) }}
    </div>
{% endblock %}
